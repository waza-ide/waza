{
  "name": "@waza/desktop",
  "version": "0.3.0",
  "private": true,
  "description": "Waza — AI-powered IDE with Monaco editor and local agent support",
  "homepage": "https://github.com/waza-ide/waza",
  "author": {
    "name": "mdl-systems",
    "email": "dev@waza-ide.dev"
  },
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm dev:main\" \"pnpm dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "pnpm build:renderer && pnpm build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "electron": "electron .",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "package": "electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@waza/core": "workspace:*",
    "@waza/ui": "workspace:*",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "monaco-editor": "^0.47.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^8.2.0",
    "diff": "^9.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.1",
    "wait-on": "^7.2.0"
  }
}
