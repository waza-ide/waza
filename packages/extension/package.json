{
  "name": "waza",
  "displayName": "Waza \u2014 AI IDE",
  "description": "Privacy-first AI coding agent. Local models supported.",
  "version": "1.5.0",
  "publisher": "waza-ide",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "ide",
    "local-model",
    "ollama",
    "privacy",
    "copilot",
    "cursor",
    "waza"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waza-ide/waza"
  },
  "bugs": {
    "url": "https://github.com/waza-ide/waza/issues"
  },
  "homepage": "https://github.com/waza-ide/waza#readme",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "waza.openPanel",
        "title": "Waza: Open Agent Panel"
      },
      {
        "command": "waza.runAgent",
        "title": "Waza: Run Agent"
      },
      {
        "command": "waza.selectModel",
        "title": "Waza: Select Model"
      },
      {
        "command": "waza.stopAgent",
        "title": "Waza: Stop Agent"
      }
    ],
    "keybindings": [
      {
        "command": "waza.openPanel",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w"
      }
    ],
    "configuration": {
      "title": "Waza",
      "properties": {
        "waza.preferLocalModel": {
          "type": "boolean",
          "default": true,
          "description": "\u30ed\u30fc\u30ab\u30eb\u30e2\u30c7\u30eb\u3092\u512a\u5148\u3057\u3066\u4f7f\u7528\u3059\u308b"
        },
        "waza.localModelUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "\u30ed\u30fc\u30ab\u30eb\u30e2\u30c7\u30eb\u30b5\u30fc\u30d0\u30fc\u306e URL"
        },
        "waza.cloudModel": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "description": "\u30af\u30e9\u30a6\u30c9\u30d5\u30a9\u30fc\u30eb\u30d0\u30c3\u30af\u6642\u306b\u4f7f\u7528\u3059\u308b\u30e2\u30c7\u30eb"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package --no-dependencies",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@waza/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.87.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.24.0",
    "vitest": "^1.4.0"
  }
}
