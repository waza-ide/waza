{
  "name": "waza",
  "displayName": "Waza — AI IDE",
  "description": "Privacy-first AI coding agent. Local models supported.",
  "version": "0.5.1",
  "publisher": "waza-ide",
  "engines": {
    "vscode": "^1.87.0"
  },
  "categories": ["AI", "Other"],
  "keywords": [
    "ai", "agent", "ide", "local-model", "ollama",
    "privacy", "copilot", "cursor", "waza"
  ],
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/waza-ide/waza"
  },
  "bugs": {
    "url": "https://github.com/waza-ide/waza/issues"
  },
  "homepage": "https://github.com/waza-ide/waza#readme",
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "waza.openPanel",
        "title": "Waza: Open Agent Panel"
      },
      {
        "command": "waza.runAgent",
        "title": "Waza: Run Agent"
      },
      {
        "command": "waza.selectModel",
        "title": "Waza: Select Model"
      },
      {
        "command": "waza.stopAgent",
        "title": "Waza: Stop Agent"
      }
    ],
    "keybindings": [
      {
        "command": "waza.openPanel",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w"
      }
    ],
    "configuration": {
      "title": "Waza",
      "properties": {
        "waza.preferLocalModel": {
          "type": "boolean",
          "default": true,
          "description": "ローカルモデルを優先して使用する"
        },
        "waza.localModelUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "ローカルモデルサーバーの URL"
        },
        "waza.cloudModel": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "description": "クラウドフォールバック時に使用するモデル"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "package": "vsce package --no-dependencies",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@waza/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.87.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^2.24.0",
    "vitest": "^1.4.0"
  }
}
